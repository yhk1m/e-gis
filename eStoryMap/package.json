{
  "name": "e-gistory",
  "productName": "e-GIS",
  "version": "0.3.1",
  "description": "e-GIS 데스크톱 — 웹 GIS + 스토리맵(e-GIStory) 통합 앱",
  "main": "dist-electron/main.js",
  "author": "김용현",
  "private": true,
  "scripts": {
    "dev": "vite",
    "clean": "node scripts/clean.js",
    "build": "node scripts/clean.js && vite build && electron-builder",
    "build:unpack": "node scripts/clean.js && vite build && electron-builder --dir",
    "build:viewer": "node scripts/build-viewer.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource/noto-sans-kr": "^5.2.9",
    "@fontsource/noto-serif-kr": "^5.2.9",
    "@supabase/supabase-js": "^2.110.0",
    "dompurify": "^3.4.11",
    "geotiff": "^2.1.3",
    "marked": "^18.0.5",
    "ol": "^9.0.0",
    "proj4": "^2.20.9"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "jsdom": "^24.0.0",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "kr.egis.egistory",
    "productName": "e-GIS",
    "copyright": "© 2026 김용현",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json",
      "!node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "e-GIS"
    },
    "artifactName": "${productName}-Setup-${version}.${ext}"
  }
}
